# Port to expose the service on
HOST_PORT=8080

# Rust logging level (trace, debug, info, warn, error)
RUST_LOG=info

# Model configuration (here azzurra-voice as an example)
MODEL_ID=cartesia/azzurra-voice
# MODEL_PATH=/models/your-local-model
# MODEL_FILE=model.safetensors

# Optional API key for authentication
# API_KEY=your-secret-key-here

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
